DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,studysphere.app,www.studysphere.app
CSRF_TRUSTED_ORIGINS=https://studysphere.app,https://www.studysphere.app

# Set USE_SQLITE=1 to use SQLite locally (e.g. when Supabase IP allow list blocks you)
# USE_SQLITE=1

DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_HOST=your-supabase-host-here
DB_PORT=5432

# ========== Email (password reset, account activation) ==========
# By default, emails are printed to the console (no real sending).
# To send real emails, set EMAIL_BACKEND and configure SMTP below.

# Use SMTP backend to send real emails:
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=StudySphere <noreply@studysphere.app>

# --- Option A: Gmail ---
# 1. Enable 2FA on your Google account
# 2. Create an App Password: Google Account → Security → App passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password

# --- Option B: SendGrid ---
# Get API key from https://sendgrid.com
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key

# --- Option C: Mailgun ---
# Get credentials from https://mailgun.com
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=postmaster@your-domain.mailgun.org
# EMAIL_HOST_PASSWORD=your-mailgun-password

# --- Option D: Resend ---
# Get API key from https://resend.com
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=465
# EMAIL_USE_SSL=true
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=re_your-api-key
